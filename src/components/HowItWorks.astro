<section class="block" id="how">
  <div class="block-head">
    <div class="block-num">01 / how</div>
    <h2>three steps. <span class="dim">no app, no setup.</span></h2>
  </div>
  <div class="steps">
    <div class="num"></div>
    <div class="body">
      <div class="step">
        <div class="step-i">i</div>
        <div>
          <h3>follow the account</h3>
          <p>
            visit <span class="tok">@lunafications.blue</span> on bluesky and
            follow it. the bot follows you back automatically.
          </p>
        </div>
      </div>
      <div class="step">
        <div class="step-i">ii</div>
        <div>
          <h3>send "menu"</h3>
          <p>
            open a DM and type <span class="tok">menu</span>. the bot replies
            with everything it can do.
          </p>
        </div>
      </div>
      <div class="step">
        <div class="step-i">iii</div>
        <div>
          <h3>tell it what to watch</h3>
          <p>
            reply with a command — <span class="tok">notify all</span>, <span
              class="tok">notify posts @friend</span
            >, etc. change your mind any time.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
