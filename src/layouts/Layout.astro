---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "lunafications — a Bluesky bot for everything Bluesky won't tell you",
  description = "Get a DM when someone blocks you, lists you, or when an account you care about posts on Bluesky.",
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    {/* Privacy-friendly analytics by Plausible */}
    <script
      is:inline
      async
      src="https://plausible.io/js/pa-CkU-LUArppb34m-KJySdU.js"></script>
    <script is:inline>
      window.plausible = window.plausible ||
        function () {
          (plausible.q = plausible.q || []).push(arguments);
        };
      plausible.init = plausible.init || function (i) {
        plausible.o = i || {};
      };
      plausible.init();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
